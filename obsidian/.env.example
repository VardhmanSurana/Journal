# Delta Exchange API credentials
# Get these from: https://www.delta.exchange/app/account/api
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# Set to "india" to use api.india.delta.exchange, or "global" for api.delta.exchange
DELTA_REGION=india

# Absolute path to your Obsidian vault folder
VAULT_PATH=/home/your_username/Obsidian/TradingJournal

# India tax rate on crypto derivatives profits (30% flat as of FY2022-23)
TAX_RATE=0.30

# How many fills to fetch per sync (max 100 per page, script handles pagination)
PAGE_LIMIT=100

# --- AI Insights (Choose one: Google AI Studio OR Vertex AI) ---
# For Google AI Studio:
GEMINI_API_KEY=

# For Vertex AI (set USE_VERTEX_AI=true to enable):
USE_VERTEX_AI=false
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
