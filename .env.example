# =============================================================================
# Delta Journal - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!

# =============================================================================
# DELTA EXCHANGE API
# =============================================================================
# Get your API keys from: https://www.delta.exchange/app/account/api
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# Region: "india" for api.india.delta.exchange, "global" for api.delta.exchange
DELTA_REGION=india

# =============================================================================
# OBSIDIAN VAULT (Obsidian Sync App Only)
# =============================================================================
# Absolute path to your Obsidian vault folder
VAULT_PATH=/path/to/your/Obsidian/Vault

# Subfolder name inside the vault root (leave empty if vault root is the journal)
VAULT_SUBDIR=

# =============================================================================
# TAX CONFIGURATION
# =============================================================================
# Your personal income tax slab rate.
# Crypto FUTURES on Delta = speculative business income = YOUR SLAB RATE (not flat 30%)
# Flat 30% only applies to spot VDA transfers (Section 115BBH)
# Common slabs: 0.05, 0.10, 0.20, 0.30
INCOME_TAX_SLAB=0.30

# =============================================================================
# SYNC SETTINGS
# =============================================================================
# How many fills to fetch per sync (max 100 per page, script handles pagination)
PAGE_LIMIT=100

# =============================================================================
# AI COACH (Optional - Vertex AI / Gemini)
# =============================================================================
USE_VERTEX_AI=false
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash

# Alternative: Direct Gemini API key (if not using Vertex AI)
GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# NOTIFICATIONS (Optional)
# =============================================================================
# Webhook URL for P&L alerts (e.g., Discord, Slack, Telegram)
WEBHOOK_URL=

# Alert threshold for large P&L changes (e.g., 100.0)
PNL_ALERT_THRESHOLD=100.0

# =============================================================================
# MARKET DATA (Optional)
# =============================================================================
# API key for CryptoCompare news (free tier available)
# Get from: https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key

# =============================================================================
# DATABASE (Backend App Only)
# =============================================================================
# SQLite database URL
DATABASE_URL=sqlite:///./app.db

# =============================================================================
# FRONTEND (React App Only)
# =============================================================================
# Backend API URL (used by the frontend)
VITE_API_URL=http://localhost:8000/api