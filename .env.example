# =============================================================================
# Delta Journal - Essential Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.

# === DELTA EXCHANGE API ===
# Get your API keys from: https://www.delta.exchange/app/account/api
DELTA_API_KEY=your_trading_api_key
DELTA_API_SECRET=your_trading_api_secret

# Region: "india" (api.india.delta.exchange) or "global" (api.delta.exchange)
DELTA_REGION=india

# === SECURITY (Recommended) ===
# Separate read-only keys for journaling/analytics to protect your account.
DELTA_READ_ONLY_KEY=your_read_only_key
DELTA_READ_ONLY_SECRET=your_read_only_secret

# === AI COACH & MARKET DATA ===
# Direct Gemini API key for trade analysis
GEMINI_API_KEY=your_gemini_api_key

# API key for CryptoCompare news feed
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key

# === NOTIFICATIONS (Optional) ===
# Webhook URL for P&L alerts (Discord/Slack/Telegram)
WEBHOOK_URL=
PNL_ALERT_THRESHOLD=100.0